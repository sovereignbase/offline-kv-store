{
  "type": "module",
  "license": "Apache-2.0",
  "name": "@sovereignbase/offline-kv-store",
  "version": "1.0.0",
  "description": "Namespace-scoped key-value storage on top of IndexedDB with explicit error codes.",
  "keywords": [
    "indexeddb",
    "kv-store",
    "key-value",
    "offline",
    "browser-storage",
    "local-first",
    "typescript",
    "sovereignbase"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "format": "prettier . --write",
    "build": "tsup",
    "test": "npm run build && node test/run-coverage.mjs && node test/e2e/run.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "c8": "^11.0.0",
    "edge-runtime": "^4.0.1",
    "fake-indexeddb": "^6.2.5",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.79.0"
  },
  "dependencies": {
    "@sovereignbase/bytecodec": "^1.5.1",
    "@sovereignbase/cryptosuite": "^2.0.5",
    "@sovereignbase/observed-remove-set": "^1.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sovereignbase/offline-kv-store.git"
  },
  "bugs": {
    "url": "https://github.com/sovereignbase/offline-kv-store/issues"
  },
  "homepage": "https://github.com/sovereignbase/offline-kv-store#readme"
}
